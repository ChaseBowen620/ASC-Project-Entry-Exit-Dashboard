# Copy to .env and set values. SECRET_KEY is required — Django will not start without it.
SECRET_KEY=change-me-to-a-long-random-string
# Use True only on trusted local machines; production should use DEBUG=False
DEBUG=True

# Dashboard API login — used to issue JWTs at POST /api/token/
DASHBOARD_USERNAME=
DASHBOARD_PASSWORD=

# Comma-separated hosts beyond defaults (e.g. EC2 public IP when Qualtrics webhook URL uses raw IP)
# EXTRA_ALLOWED_HOSTS=54.x.x.x

# Qualtrics webhook — must match the custom header value in your Qualtrics workflow HTTP task
QUALTRICS_WEBHOOK_SECRET=
# Optional: custom header name from Qualtrics (default: Qualtrics-Webhook-Secret)
# QUALTRICS_WEBHOOK_HEADER=Qualtrics-Webhook-Secret

# JWT httpOnly cookies: set JWT_COOKIE_SECURE=False for local HTTP dev (default when DEBUG=True).
# JWT_COOKIE_SECURE=True
# For cross-subdomain API vs frontend (HTTPS only): JWT_COOKIE_SAMESITE=None and JWT_COOKIE_DOMAIN=.example.com
# JWT_COOKIE_DOMAIN=
# JWT_COOKIE_SAMESITE=Lax

# When DEBUG=False and Django handles HTTPS directly:
# SECURE_SSL_REDIRECT=True
# Behind nginx/ELB TLS termination, often SECURE_SSL_REDIRECT=False and set SECURE_PROXY_SSL_HEADER in settings if needed.
